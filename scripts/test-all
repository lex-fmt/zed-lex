#!/usr/bin/env bash
# test-all: single entry point for all zed-lex quality checks.
#
# Runs the same checks in every context: pre-commit hook, CI, manual.
#
# Usage:
#   ./scripts/test-all              # full check (bats needs grammar)
#   ./scripts/test-all --quick      # skip query smoke test (no network)
#
# Pipeline:
#   1. cargo fmt --check
#   2. cargo clippy --target wasm32-wasip2 -D warnings
#   3. cargo build --release --target wasm32-wasip2
#   4. bats test/manifest.bats   (extension.toml + lex-deps.json shape)
#   5. bats test/queries.bats    (query parses + capture-shape regressions)
#
# Filter inside bats with `bats --filter <pattern> test/`.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$REPO_DIR"

QUICK=false
for arg in "$@"; do
    case "$arg" in
        --quick) QUICK=true ;;
        -h|--help)
            sed -n '2,18p' "$0"
            exit 0
            ;;
        *) echo "Unknown arg: $arg" >&2; exit 2 ;;
    esac
done

FAILED=false
WASM_TARGET="wasm32-wasip2"

step() { echo; echo "═══ $* ═══"; }

# --- 1. cargo fmt ---
step "cargo fmt --check"
if ! cargo fmt --all -- --check; then
    echo "Run: cargo fmt"
    FAILED=true
fi

# --- 2. cargo clippy (wasm target) ---
step "cargo clippy --target $WASM_TARGET"
if ! cargo clippy --release --target "$WASM_TARGET" -- -D warnings; then
    FAILED=true
fi

# --- 3. build the publishable WASM via scripts/build ---
# scripts/build is the single entry point for "compile to wasm32-wasip2".
# Calling it here (rather than `cargo build` directly) keeps build logic
# in one place and exercises the same code path the release workflow uses.
if ! "$SCRIPT_DIR/build"; then
    FAILED=true
fi

# --- 4. bats manifest tests ---
step "bats test/manifest.bats"
if ! bats test/manifest.bats; then
    FAILED=true
fi

# --- 5. bats query tests (skippable) ---
if $QUICK; then
    step "bats test/queries.bats (skipped: --quick)"
else
    step "bats test/queries.bats"
    if ! bats test/queries.bats; then
        FAILED=true
    fi
fi

# --- summary ---
echo
if $FAILED; then
    echo "RESULT: FAIL"
    exit 1
fi
echo "RESULT: PASS"
