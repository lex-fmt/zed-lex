#!/usr/bin/env bash
set -euo pipefail

# Create a release: validate, sync extension.toml + Cargo.toml versions,
# update CHANGELOG.md, clear UNRELEASED.md, commit, create annotated tag
# (with release notes), and push.
#
# The CI release workflow reads the tag annotation to populate the
# GitHub release body — no file parsing on the server side.
#
# This script mirrors the tree-sitter-lex / lex / nvim convention so
# every repo cuts releases the same way.

usage() {
    echo "Usage: $(basename "$0") <version>"
    echo ""
    echo "  version   Tag name, e.g. v0.2.0"
    echo ""
    echo "Reads UNRELEASED.md for release notes, prepends them to"
    echo "CHANGELOG.md, syncs extension.toml + Cargo.toml versions,"
    echo "commits, tags (annotated), and pushes."
}

if [[ $# -ne 1 ]]; then
    usage >&2
    exit 1
fi

VERSION="$1"
if [[ ! "$VERSION" =~ ^v[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "error: version must match vX.Y.Z (got: $VERSION)" >&2
    exit 1
fi
VERSION_NO_V="${VERSION#v}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$REPO_ROOT"

# --- Guards ---

if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "error: working tree is not clean" >&2
    exit 1
fi

if git rev-parse "$VERSION" >/dev/null 2>&1; then
    echo "error: tag $VERSION already exists" >&2
    exit 1
fi

# --- Read release notes ---

UNRELEASED="$REPO_ROOT/UNRELEASED.md"
if [[ ! -f "$UNRELEASED" ]]; then
    echo "error: UNRELEASED.md not found" >&2
    exit 1
fi

# Strip HTML comment lines, trim leading/trailing blank lines
NOTES=$(grep -v '^<!--.*-->$' "$UNRELEASED" | sed -e '/./,$!d' -e :a -e '/^\n*$/{$d;N;ba' -e '}')

if [[ -z "$NOTES" ]]; then
    echo "error: UNRELEASED.md has no release notes" >&2
    exit 1
fi

echo "Release notes for $VERSION:"
echo "---"
echo "$NOTES"
echo "---"
echo

# --- Sync versions in extension.toml + Cargo.toml ---

python3 - <<PY
import re
from pathlib import Path

ext = Path("extension.toml")
text = ext.read_text()
text = re.sub(r'^version = "[^"]+"', 'version = "$VERSION_NO_V"', text, count=1, flags=re.M)
ext.write_text(text)

cargo = Path("Cargo.toml")
text = cargo.read_text()
text = re.sub(r'^version = "[^"]+"', 'version = "$VERSION_NO_V"', text, count=1, flags=re.M)
cargo.write_text(text)
PY

# --- Update CHANGELOG.md ---

CHANGELOG="$REPO_ROOT/CHANGELOG.md"
DATE=$(date +%Y-%m-%d)
ENTRY="## $VERSION ($DATE)

$NOTES"

if [[ -f "$CHANGELOG" ]]; then
    HEADER=$(head -n 1 "$CHANGELOG")
    TAIL=$(tail -n +2 "$CHANGELOG")
    printf '%s\n\n%s\n%s\n' "$HEADER" "$ENTRY" "$TAIL" > "$CHANGELOG"
else
    printf '%s\n\n%s\n' "# Changelog" "$ENTRY" > "$CHANGELOG"
fi

# --- Reset UNRELEASED.md ---

cat > "$UNRELEASED" <<'TEMPLATE'
<!-- Release notes for the next version. -->
<!-- Updated as work is done; consumed by scripts/create-release. -->
TEMPLATE

# --- Re-run tests to confirm version sync didn't break anything ---

echo "Verifying repo still builds + passes tests..."
"$SCRIPT_DIR/test-all" --quick

# --- Commit, tag, push ---

git add CHANGELOG.md UNRELEASED.md extension.toml Cargo.toml Cargo.lock
git commit -m "Release $VERSION"
git tag -a "$VERSION" -m "$NOTES"
git push
git push origin "$VERSION"

echo
echo "Released $VERSION — CI will build the artifact and create the GitHub release."
